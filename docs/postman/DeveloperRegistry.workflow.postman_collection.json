{
  "info": {
    "_postman_id": "7f8ab5d2-6d36-45ae-ae66-882724f8f112",
    "name": "DeveloperRegistry - Full Workflow",
    "description": "End-to-end command + query workflow for DeveloperRegistry API. Run requests top-to-bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.collectionVariables.set('correlationId', pm.variables.replaceIn('{{$guid}}'));",
          "if (!pm.collectionVariables.get('runSuffix')) {",
          "  pm.collectionVariables.set('runSuffix', pm.variables.replaceIn('{{$timestamp}}'));",
          "}",
          "if (!pm.collectionVariables.get('applicationName')) {",
          "  pm.collectionVariables.set('applicationName', 'Portal-' + pm.collectionVariables.get('runSuffix'));",
          "}",
          "if (!pm.collectionVariables.get('applicationDescription')) {",
          "  pm.collectionVariables.set('applicationDescription', 'Developer portal for full workflow run');",
          "}",
          "if (!pm.collectionVariables.get('ownerName')) {",
          "  pm.collectionVariables.set('ownerName', 'Platform Owner ' + pm.collectionVariables.get('runSuffix'));",
          "}",
          "if (!pm.collectionVariables.get('ownerEmail')) {",
          "  pm.collectionVariables.set('ownerEmail', 'owner+' + pm.collectionVariables.get('runSuffix') + '@example.com');",
          "}",
          "if (!pm.collectionVariables.get('apiKeyName')) {",
          "  pm.collectionVariables.set('apiKeyName', 'Primary Key');",
          "}",
          "if (!pm.collectionVariables.get('webhookEventName')) {",
          "  pm.collectionVariables.set('webhookEventName', 'application.updated');",
          "}",
          "if (!pm.collectionVariables.get('webhookUrl')) {",
          "  pm.collectionVariables.set('webhookUrl', 'https://webhook.site/replace-me');",
          "}"
        ]
      }
    }
  ],
